<Project>

  <ItemGroup>
    <ProjectReference Include="$(MSBuildThisFileDirectory)..\src\Catan.Modes.Standard\Catan.Modes.Standard.csproj" ReferenceOutputAssembly="false" Private="false" />
    <ProjectReference Include="$(MSBuildThisFileDirectory)..\src\Catan.Modes.Seafarers\Catan.Modes.Seafarers.csproj" ReferenceOutputAssembly="false" Private="false" />
    <ProjectReference Include="$(MSBuildThisFileDirectory)..\src\Catan.Modes.Mini\Catan.Modes.Mini.csproj" ReferenceOutputAssembly="false" Private="false" />
  </ItemGroup>

  <Target Name="CopyPlugins" AfterTargets="Build">
    <ItemGroup>
      <PluginDll Include="$(MSBuildThisFileDirectory)..\src\Catan.Modes.Standard\bin\$(Configuration)\net9.0\Catan.Modes.Standard.dll" />
      <PluginDll Include="$(MSBuildThisFileDirectory)..\src\Catan.Modes.Seafarers\bin\$(Configuration)\net9.0\Catan.Modes.Seafarers.dll" />
      <PluginDll Include="$(MSBuildThisFileDirectory)..\src\Catan.Modes.Mini\bin\$(Configuration)\net9.0\Catan.Modes.Mini.dll" />
    </ItemGroup>
    <Copy SourceFiles="@(PluginDll)" DestinationFolder="$(OutDir)plugins" SkipUnchangedFiles="true" />
  </Target>

</Project>

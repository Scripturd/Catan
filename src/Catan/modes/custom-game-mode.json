{
  // A copy of the Standard board. Use this as a starting point for your own
  // game mode: rename it, edit the hexes/harbours below, drop it in the modes
  // folder, and it appears in the game's mode list automatically.
  "name": "Custom Game Mode (copy of Standard)",

  // How many players your board supports.
  "minPlayers": 3,
  "maxPlayers": 4,

  // true  = shuffle the land terrains among the land hexes on every game.
  // false = keep each hex's terrain exactly as written below (a fixed layout).
  "randomizeTerrain": true,
  // true  = shuffle the number tokens among the productive hexes every game.
  // false = place each token on the hex it is written on.
  "randomizeTokens": true,

  // Each hex is an axial coordinate (q, r) plus a terrain.
  // Terrain options: Forest, Hills, Pasture, Fields, Mountains, Desert, Sea, Gold.
  // "token" (2-12, never 7) is required on every productive land hex
  // (everything except Desert and Sea) and must be omitted elsewhere.
  "hexes": [
    { "q": 0, "r": -2, "terrain": "Desert" },
    { "q": 1, "r": -2, "terrain": "Forest", "token": 5 },
    { "q": 2, "r": -2, "terrain": "Forest", "token": 2 },
    { "q": -1, "r": -1, "terrain": "Forest", "token": 6 },
    { "q": 0, "r": -1, "terrain": "Forest", "token": 3 },
    { "q": 1, "r": -1, "terrain": "Fields", "token": 8 },
    { "q": 2, "r": -1, "terrain": "Fields", "token": 10 },
    { "q": -2, "r": 0, "terrain": "Fields", "token": 9 },
    { "q": -1, "r": 0, "terrain": "Fields", "token": 12 },
    { "q": 0, "r": 0, "terrain": "Pasture", "token": 11 },
    { "q": 1, "r": 0, "terrain": "Pasture", "token": 4 },
    { "q": 2, "r": 0, "terrain": "Pasture", "token": 8 },
    { "q": -2, "r": 1, "terrain": "Pasture", "token": 10 },
    { "q": -1, "r": 1, "terrain": "Hills", "token": 9 },
    { "q": 0, "r": 1, "terrain": "Hills", "token": 4 },
    { "q": 1, "r": 1, "terrain": "Hills", "token": 5 },
    { "q": -2, "r": 2, "terrain": "Mountains", "token": 6 },
    { "q": -1, "r": 2, "terrain": "Mountains", "token": 3 },
    { "q": 0, "r": 2, "terrain": "Mountains", "token": 11 }
  ],

  // Harbours sit on a coastal edge (q, r, direction).
  // direction options: East, SouthEast, SouthWest.
  // "ratio" 3 with no resource = generic 3:1 port; ratio 2 + a resource = 2:1.
  "harbours": [
    { "edge": { "q": 0, "r": -3, "direction": "SouthEast" }, "ratio": 3 },
    { "edge": { "q": 2, "r": -3, "direction": "SouthWest" }, "ratio": 2, "resource": "Wool" },
    { "edge": { "q": -2, "r": -1, "direction": "East" }, "ratio": 2, "resource": "Ore" },
    { "edge": { "q": 3, "r": -2, "direction": "SouthWest" }, "ratio": 3 },
    { "edge": { "q": 2, "r": 0, "direction": "East" }, "ratio": 3 },
    { "edge": { "q": -3, "r": 1, "direction": "East" }, "ratio": 2, "resource": "Grain" },
    { "edge": { "q": 1, "r": 1, "direction": "SouthEast" }, "ratio": 2, "resource": "Brick" },
    { "edge": { "q": -2, "r": 2, "direction": "SouthWest" }, "ratio": 3 },
    { "edge": { "q": -1, "r": 2, "direction": "SouthEast" }, "ratio": 2, "resource": "Lumber" }
  ]
}
